# Copie ce fichier en .env et renseigne tes cles. NE JAMAIS committer .env.
# La cle Acceslibre n'est utilisee QU'au build (pipeline / GitHub Actions), jamais cote navigateur.
ACCESLIBRE_API_KEY=

# Optionnel : token Mapillary (imagerie de rue). Sans lui, seule Panoramax est active.
# Cote frontend, exposer via VITE_MAPILLARY_TOKEN (client token, visible dans le navigateur).
VITE_MAPILLARY_TOKEN=
